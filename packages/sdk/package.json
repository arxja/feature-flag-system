{
  "name": "@arxja/feature-flags-sdk",
  "version": "1.0.0",
  "description": "Feature Flag SDK for React and Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/react/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/react/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["feature-flags", "toggle", "react", "nodejs", "sdk"],
  "author": "Arash Jafari",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
